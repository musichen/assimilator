# ASSIMILATOR environment example
#
# Copy this file to .env for local development.
# Never commit real tokens, keys, private paths, or machine-specific values.

# Optional workspace override. Defaults to ./knowledge-system.
ASSIMILATOR_WORKSPACE=knowledge-system

# Telegram bot token from BotFather. Required only for `pnpm telegram`.
BOT_key=<telegram-bot-token>

# Optional converter/provider keys for media features that need external services.
# Leave unset for local-first usage.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional converter binary overrides.
ASSIMILATOR_MARKITDOWN_BIN=
ASSIMILATOR_YTDLP_BIN=
